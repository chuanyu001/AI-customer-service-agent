# AI客服Agent 环境配置
# 复制此文件为 .env 并修改配置

# ============================================
# 应用配置
# ============================================
APP_NAME=AI-Customer-Service-Agent
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=change-me-to-a-random-secret-key

# ============================================
# MySQL 数据库
# ============================================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=kefu_agent
MYSQL_POOL_SIZE=20
MYSQL_POOL_RECYCLE=3600

# ============================================
# Redis
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_SESSION_TTL=86400

# ============================================
# 本地LLM (Ollama)
# ============================================
LLM_PROVIDER=local
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen2.5:7b
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048
LLM_TIMEOUT=30

# 备用LLM (豆包/Doubao, 可选)
BACKUP_LLM_PROVIDER=doubao
BACKUP_LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
BACKUP_LLM_API_KEY=your_doubao_api_key
BACKUP_LLM_MODEL=ep-xxx

# ============================================
# 向量化服务
# ============================================
EMBEDDING_MODEL=shibing624/text2vec-base-chinese
EMBEDDING_DEVICE=cpu

# ============================================
# 七鱼客服
# ============================================
QIYU_ENABLED=false
QIYU_BASE_URL=
QIYU_APP_KEY=
QIYU_APP_SECRET=

# ============================================
# 业务配置
# ============================================
BUSINESS_HOURS_START=09:00
BUSINESS_HOURS_END=18:00
MAX_CONSECUTIVE_FAIL=3
SESSION_TIMEOUT_MINUTES=30
MAX_SLOT_RETRY=2
